---
interface Props {
  text: string;
  active?: boolean;
}

const { text, active = false } = Astro.props;
---

<span class={`token-pill ${active ? "is-active" : ""}`}>{text}</span>

<style>
  .token-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.32rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(14, 165, 198, 0.25);
    background: rgba(14, 165, 198, 0.08);
    color: #155e75;
    font-size: 0.78rem;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
  }

  .token-pill.is-active {
    background: rgba(14, 165, 198, 0.18);
    border-color: rgba(14, 165, 198, 0.5);
    color: #0f3a47;
  }
</style>
