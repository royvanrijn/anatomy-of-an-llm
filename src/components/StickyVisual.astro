---
interface Props {
  title?: string;
}

const { title = "Visual" } = Astro.props;
---

<aside class="sticky-visual" aria-label={title}>
  <header class="sticky-visual-header">
    <p>{title}</p>
  </header>
  <div class="sticky-visual-body">
    <slot />
  </div>
</aside>

<style>
  .sticky-visual {
    position: sticky;
    top: 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(170deg, rgba(255, 255, 255, 0.94), rgba(244, 239, 226, 0.92));
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .sticky-visual-header {
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
    color: #52525b;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
  }

  .sticky-visual-header p {
    margin: 0;
  }

  .sticky-visual-body {
    min-height: 260px;
    display: grid;
    place-items: center;
    color: var(--text-secondary);
    padding: 1rem;
  }

  @media (max-width: 900px) {
    .sticky-visual {
      position: static;
    }
  }
</style>
