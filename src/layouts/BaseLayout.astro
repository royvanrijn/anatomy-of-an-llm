---
import "../styles/theme.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Anatomy of an LLM",
  description = "A static interactive explainer about how modern LLMs work."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>
