---
interface Entry {
  label: string;
  value: number;
}

interface Props {
  entries?: Entry[];
}

const {
  entries = [
    { label: " calm", value: 0.33 },
    { label: " inside", value: 0.22 },
    { label: " outside", value: 0.17 },
    { label: " angry", value: 0.1 }
  ]
} = Astro.props;
---

<div class="probability-bars">
  {
    entries.map((entry) => (
      <div class="row">
        <span class="label">{entry.label}</span>
        <div class="track">
          <span class="fill" style={`width:${Math.round(entry.value * 100)}%`} />
        </div>
        <span class="value">{Math.round(entry.value * 100)}%</span>
      </div>
    ))
  }
</div>

<style>
  .probability-bars {
    display: grid;
    gap: 0.38rem;
  }

  .row {
    display: grid;
    grid-template-columns: 4.8rem 1fr auto;
    align-items: center;
    gap: 0.45rem;
  }

  .label,
  .value {
    font-size: 0.74rem;
    color: var(--text-secondary);
  }

  .track {
    border-radius: 999px;
    height: 0.5rem;
    background: rgba(2, 132, 199, 0.13);
    border: 1px solid rgba(2, 132, 199, 0.16);
  }

  .fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(2, 132, 199, 0.75), rgba(2, 132, 199, 0.35));
  }
</style>
