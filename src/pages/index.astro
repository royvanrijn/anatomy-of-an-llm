---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmbeddingChapter from "../components/chapters/EmbeddingChapter.svelte";
import SingleNeuronChapter from "../components/chapters/SingleNeuronChapter.svelte";
import NeuralNetworkChapter from "../components/chapters/NeuralNetworkChapter.svelte";
import LogitsSamplingChapter from "../components/chapters/LogitsSamplingChapter.svelte";
import BackpropagationChapter from "../components/chapters/BackpropagationChapter.svelte";
import OptimizersChapter from "../components/chapters/OptimizersChapter.svelte";
import QkvChapter from "../components/chapters/QkvChapter.svelte";
import AttentionMathChapter from "../components/chapters/AttentionMathChapter.svelte";
import RopeChapter from "../components/chapters/RopeChapter.svelte";
import TransformerBlockChapter from "../components/chapters/TransformerBlockChapter.svelte";
import TrainingPhasesChapter from "../components/chapters/TrainingPhasesChapter.svelte";
import PostTrainingChapter from "../components/chapters/PostTrainingChapter.svelte";
import TokenizationChapter from "../components/chapters/TokenizationChapter.svelte";
import ChapterShell from "../components/ChapterShell.astro";
import PrimitiveShowcase from "../components/PrimitiveShowcase.astro";
import StoryProgressNav from "../components/StoryProgressNav.astro";
import embeddingsData from "../data/generated/embeddings-o200k-base.json";
import tokenizationData from "../data/generated/tokenization-o200k-base.json";

const chapterList = [
  { id: "c1", number: "01", title: "Tokenization", status: "active" as const },
  { id: "c2", number: "02", title: "Vector Embedding", status: "active" as const },
  { id: "c3", number: "03", title: "Neuron Activation", status: "active" as const },
  { id: "c4", number: "04", title: "Feed Forward Neural Network", status: "active" as const },
  { id: "c5", number: "05", title: "Logits and Sampling", status: "active" as const },
  { id: "c6", number: "06", title: "Backpropagation", status: "active" as const },
  { id: "c7", number: "07", title: "Optimizers", status: "active" as const },
  { id: "c8", number: "08", title: "Attention Q/K/V", status: "active" as const },
  { id: "c9", number: "09", title: "Multi-Headed Attention", status: "active" as const },
  { id: "c10", number: "10", title: "RoPE", status: "active" as const },
  { id: "c11", number: "11", title: "Transformer Block", status: "active" as const },
  { id: "c12", number: "12", title: "Training Phases", status: "active" as const },
  { id: "c13", number: "13", title: "Post-Training", status: "active" as const },
  { id: "c14", number: "14", title: "Context and KV Cache", status: "planned" as const },
  { id: "c15", number: "15", title: "Quantization", status: "planned" as const }
];

const chapterNav = chapterList.map((chapter) => ({
  id: chapter.id,
  number: chapter.number,
  title: chapter.title,
  status: chapter.status
}));
---

<BaseLayout>
  <header class="hero">
    <p class="eyebrow">Interactive Explainer</p>
    <h1>The Anatomy of an LLM</h1>
    <p>
      A visual walkthrough from real GPT tokenization to transformer internals, training dynamics, inference
      trade-offs, and quantization.
    </p>
  </header>
  <StoryProgressNav chapters={chapterNav} />

  <main>
    <section id="intro" class="intro-section" aria-labelledby="intro-heading">
      <p class="intro-kicker">Introduction</p>
      <h2 id="intro-heading">Introduction</h2>
      <p class="intro-lead">
        Currently you read about LLMs everywhere, but it is still hard to see what is actually happening under the hood.
        This explainer opens the model up and follows the internal path step by step.
      </p>
      <p class="intro-pipeline">text -> tokens -> vectors -> attention -> probabilities -> sampled output</p>
      <div class="intro-grid">
        <article>
          <p>What you get</p>
          <p>Concrete visuals, small numbers first, and interactive controls that make each transformation inspectable.</p>
        </article>
        <article>
          <p>How to use it</p>
          <p>Scroll top to bottom as a single narrative, or jump between chapters for a specific concept.</p>
        </article>
        <article>
          <p>Who made this</p>
          <p>
            This explainer was created by:
          </p>
          <p>
            Roy van Rijn @ <a href="https://www.openvalue.eu">openvalue</a>
          </p>
        </article>
      </div>
      <div class="intro-toc" aria-labelledby="intro-toc-heading">
        <p id="intro-toc-heading">Table of contents</p>
        <ol>
          {
            chapterList.map((chapter) => (
              <li>
                <a href={`#${chapter.id}`}>
                  <span>{chapter.number}</span>
                  <span>{chapter.title}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    {
      chapterList.map((chapter) => (
        <div class="chapter-step">
          <ChapterShell
            id={chapter.id}
            number={chapter.number}
            title={chapter.title}
            summary={chapter.number === "01"
              ? "The first step in turning text into something a model can calculate with."
              : chapter.number === "02"
              ? "Each token ID becomes a row lookup in an embedding table, producing a high-dimensional vector."
              : chapter.number === "03"
              ? "Weighted inputs create a pre-activation value, then a non-linearity shapes the neuron output."
              : chapter.number === "04"
              ? "How feed-forward layers transform token representations using matrix multiplications and activations."
              : chapter.number === "05"
              ? "How hidden states become logits, probabilities, and finally a sampled next token."
              : chapter.number === "06"
              ? "How prediction error turns into gradients, and how one update step nudges weights to reduce loss."
              : chapter.number === "07"
              ? "How different optimizer rules use the same gradients but still produce different update trajectories."
              : chapter.number === "08"
              ? "How each token becomes Query, Key, and Value vectors, and how similarity weights mix information."
              : "How this concept fits into the LLM pipeline, with a focused visual walkthrough and a concrete practical takeaway."}
          >
            {
              chapter.number === "01" ? (
                <>
                  <p class="story-lead">
                    We start with the first thing a language model receives: text. Before any vectors, attention, or prediction
                    can happen, that text has to be rewritten as a sequence of token IDs.
                  </p>
                  <TokenizationChapter data={tokenizationData} client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Token boundaries are not always word boundaries. Spaces, punctuation, uncommon words, code, and accents
                      can all change how text is split. Everything that follows in the model starts from this sequence.
                    </p>
                  </div>
                </>
              ) : chapter.number === "02" ? (
                <>
                  <p class="story-lead">
                    Token IDs are still just symbols. The embedding layer turns each one into a numeric vector so similar
                    contexts can be represented and compared in continuous space.
                  </p>
                  <EmbeddingChapter
                    tokenizationData={tokenizationData}
                    embeddingData={embeddingsData}
                    client:load
                  />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      The model does not memorize one scalar meaning per token. It starts with a whole vector, and each
                      dimension contributes a small part of the representation used by later layers.
                    </p>
                  </div>
                </>
              ) : chapter.number === "03" ? (
                <>
                  <p class="story-lead">
                    The embedding vector then flows into neurons. Each neuron computes a weighted sum,
                    and applies an activation function to produce a transformed signal for the next layer.
                  </p>
                  <SingleNeuronChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      The activation function is not cosmetic. It changes how information can flow and is the key reason
                      stacked layers can model non-linear structure.
                    </p>
                  </div>
                </>
              ) : chapter.number === "04" ? (
                <>
                  <p class="story-lead">
                    Now we zoom in on forward computation only. The point is to connect the familiar neuron drawing to
                    the matrix form used in real implementations.
                  </p>
                  <NeuralNetworkChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      The graph and matrices are exactly the same operation. Every edge corresponds to one weight matrix
                      cell, and each layer output is computed as <code>X·W</code> before activation.
                    </p>
                  </div>
                </>
              ) : chapter.number === "05" ? (
                <>
                  <p class="story-lead">
                    After the network computes a final hidden state, we project it onto the vocabulary to get logits.
                    That means the output projection has one score per tokenizer vocabulary token
                    (output width = tokenizer vocabulary size).
                    Temperature and sampling strategy then decide how deterministic or diverse the next token is.
                  </p>
                  <LogitsSamplingChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Logits are not probabilities yet. Softmax turns relative score differences into a distribution,
                      and temperature reshapes that distribution before sampling.
                    </p>
                  </div>
                  <div class="story-beat">
                    <p>Fun fact</p>
                    <p>
                      The model becomes more and more deterministic as <code>temperature</code> approaches zero.
                    </p>
                    <p>
                      In pure math, setting temperature to <code>0.0</code> would be fully deterministic. In real systems,
                      runtime scheduling and floating-point rounding can still lead to occasional output differences.
                    </p>
                  </div>
                </>
              ) : chapter.number === "06" ? (
                <>
                  <p class="story-lead">
                    Once we have logits and a target token, we can measure error with loss. Backpropagation then sends
                    that error signal backward through the network to compute how every weight should change.
                  </p>
                  <BackpropagationChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Gradients are local pieces multiplied together by the chain rule. That is why “blame” can flow
                      from output back to earlier layers in a mathematically consistent way.
                    </p>
                  </div>
                </>
              ) : chapter.number === "07" ? (
                <>
                  <p class="story-lead">
                    Gradients tell us the direction to go. Optimizers decide how to move along that direction over time.
                    Different update rules can make training smooth, noisy, fast, or unstable.
                  </p>
                  <OptimizersChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      SGD, Momentum, and Adam can start from the same point and see the same gradients, yet follow
                      different paths because each optimizer keeps different internal state.
                    </p>
                  </div>
                </>
              ) : chapter.number === "08" ? (
                <>
                  <p class="story-lead">
                    Up to now, each token mostly carried its own transformed representation. Attention changes that:
                    every token can look at other tokens, decide which ones matter for its current context, and pull
                    a weighted mixture of their information forward.
                  </p>
                  <QkvChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Query and key vectors are only used to compute attention weights. The actual content passed onward
                      is the weighted mixture of value vectors.
                    </p>
                  </div>
                  <div class="story-beat">
                    <p>Why this helps</p>
                    <p>
                      This is the core mechanism behind context sensitivity. The same token can produce different outputs
                      in different sentences, because its attention weights can shift toward different neighbors.
                    </p>
                  </div>
                </>
              ) : chapter.number === "09" ? (
                <>
                  <p class="story-lead">
                    Now we move from intuition to exact attention math. We compute query-key scores, normalize them
                    row-wise with softmax, and use those weights to mix value vectors into a new output representation.
                   </p>
                  <AttentionMathChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      So “blue” can mostly attend to “car”, while “hit” can mostly attend to “car” and “wall”. That is why one token
                      can focus on different context than its neighbors even in the same sentence.
                    </p>
                  </div>
                </>
              ) : chapter.number === "10" ? (
                <>
                  <p class="story-lead">
                    RoPE (Rotary Positional Encoding) makes attention position-aware by rotating query and key dimension
                    pairs based on token position. This keeps token identity while changing compatibility by relative offset.
                  </p>
                  <RopeChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      RoPE is about rotating Q/K pairs, not adding a position vector. Different pair frequencies let the model
                      encode relative position structure across short and long ranges.
                    </p>
                  </div>
                </>
              ) : chapter.number === "11" ? (
                <>
                  <p class="story-lead">
                    Now we assemble one full Transformer block so each piece has a place in the bigger system:
                    norm, attention, residual connection, norm, and feed-forward network.
                  </p>
                  <TransformerBlockChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      A block is mostly shape-preserving routing and transformation. Tokens keep their row positions,
                      while their vector content is repeatedly remixed by attention and MLP layers.
                    </p>
                  </div>
                </>
              ) : chapter.number === "12" ? (
                <>
                  <p class="story-lead">
                    Next we zoom out from one block and look at training dynamics over time: rapid fitting early on,
                    slower consolidation, and sometimes delayed generalization.
                  </p>
                  <TrainingPhasesChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Training loss and validation loss do not always improve at the same pace. A late drop in
                      validation can happen after long periods where progress looks flat.
                    </p>
                  </div>
                </>
              ) : chapter.number === "13" ? (
                <>
                  <p class="story-lead">
                    After base pre-training, we tune behavior in stages: instruction-following first, then preference
                    alignment. The capability base is similar, but output style and helpfulness shift a lot.
                  </p>
                  <PostTrainingChapter client:load />
                  <div class="story-beat">
                    <p>The thing to notice</p>
                    <p>
                      Pre-training builds broad competence. Post-training mostly steers how that competence is used:
                      directness, formatting, and alignment with user intent.
                    </p>
                  </div>
                </>
              ) : (
                <>
                  <p class="story-lead">
                    This chapter is now a real scroll target and will become a dedicated explanatory beat in the full experience.
                  </p>
                  <div class="story-beat">
                    <p>Context</p>
                    <p>Explain why this concept matters in the larger LLM pipeline.</p>
                  </div>
                  <div class="story-beat">
                    <p>Mechanism</p>
                    <p>Show the key mental model with one visual and one equation or transformation.</p>
                  </div>
                  <PrimitiveShowcase chapterNumber={chapter.number} />
                  <div class="story-beat">
                    <p>Takeaway</p>
                    <p>Summarize what changes when scaling from toy values to real model settings.</p>
                  </div>
                </>
              )
            }
          </ChapterShell>
        </div>
      ))
    }
  </main>
</BaseLayout>

<style>
  .hero {
    margin: 0 0 1.4rem;
    padding: 1.8rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background:
      radial-gradient(circle at 75% 0%, rgba(21, 106, 130, 0.12), transparent 40%),
      linear-gradient(140deg, rgba(255, 255, 255, 0.9), rgba(245, 240, 227, 0.84));
  }

  .eyebrow {
    margin: 0;
    color: #57534e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  h1 {
    margin: 0.45rem 0;
    font-size: clamp(2rem, 5vw, 3.4rem);
    color: #111827;
    font-family: "Fraunces", "Iowan Old Style", "Georgia", serif;
    font-weight: 500;
    letter-spacing: -0.015em;
  }

  .hero p {
    max-width: 70ch;
    margin: 0;
    color: var(--text-secondary);
  }

  .chapter-step {
    min-height: auto;
    padding: 1.1rem 0 3.2rem;
    border-top: 1px solid rgba(63, 63, 70, 0.1);
  }

  .chapter-step:first-of-type {
    border-top: 0;
  }

  .story-lead {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .story-beat {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.52);
    padding: 0.8rem 0.9rem;
  }

  .story-beat p {
    margin: 0;
  }

  .story-beat p:first-child {
    color: #52525b;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    margin-bottom: 0.3rem;
  }

  .intro-section {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 85% -10%, rgba(21, 106, 130, 0.18), transparent 45%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(247, 243, 233, 0.88));
    box-shadow: var(--shadow-soft);
    padding: 1.4rem 1.45rem;
    margin: 0 0 1.2rem;
    display: grid;
    gap: 0.85rem;
  }

  .intro-kicker {
    margin: 0;
    color: #155e75;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
  }

  .intro-section h2 {
    margin: 0;
    font-size: clamp(1.65rem, 3.5vw, 2.5rem);
    font-family: "Fraunces", "Iowan Old Style", "Georgia", serif;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: #111827;
  }

  .intro-lead {
    margin: 0;
    color: #27272a;
    max-width: 88ch;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .intro-pipeline {
    margin: 0;
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.92rem;
    color: #334155;
    letter-spacing: 0.01em;
    background: rgba(21, 106, 130, 0.06);
    border: 1px solid rgba(21, 106, 130, 0.2);
    border-radius: 10px;
    padding: 0.4rem 0.55rem;
    display: inline-block;
    max-width: 100%;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .intro-grid article {
    border: 1px solid rgba(39, 39, 42, 0.12);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.72);
    padding: 0.62rem 0.68rem;
    display: grid;
    gap: 0.3rem;
  }

  .intro-grid article p {
    margin: 0;
  }

  .intro-grid article p:first-child {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #52525b;
  }

  .intro-toc {
    margin-top: 1rem;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    background: rgba(255, 252, 244, 0.62);
    padding: 0.9rem;
    display: grid;
    gap: 0.55rem;
  }

  .intro-toc > p {
    margin: 0;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .intro-toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.28rem;
  }

  .intro-toc a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    padding: 0.18rem 0.28rem;
    transition: color 180ms ease, background-color 180ms ease;
  }

  .intro-toc a:hover,
  .intro-toc a:focus-visible {
    color: var(--text-primary);
    background: rgba(21, 106, 130, 0.08);
    outline: none;
  }

  .intro-toc a span:first-child {
    font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
    font-size: 0.73rem;
    color: var(--text-muted);
  }

  .intro-grid article p:last-child {
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .chapter-step {
      min-height: auto;
      padding: 0.8rem 0 2rem;
    }

    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
