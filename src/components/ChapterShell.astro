---
interface Props {
  id: string;
  number: string;
  title: string;
  summary: string;
}

const { id, number, title, summary } = Astro.props;
---

<section id={id} class="chapter-shell" aria-labelledby={`chapter-${number}`}>
  <div class="chapter-content">
    <article class="chapter-main">
      <p class="chapter-kicker">Chapter {number}</p>
      <h2 id={`chapter-${number}`}>{title}</h2>
      <p class="chapter-summary">{summary}</p>
      <div class="chapter-body">
        <slot />
      </div>
    </article>
  </div>
</section>

<style>
  .chapter-shell {
    scroll-margin-top: 6rem;
  }

  .chapter-content {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .chapter-main {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 239, 0.9) 54%, rgba(246, 239, 224, 0.82));
    box-shadow: var(--shadow-soft);
    padding: 1.45rem;
  }

  .chapter-kicker {
    margin: 0;
    color: #52525b;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.4rem, 2.8vw, 2.1rem);
    font-family: "Fraunces", "Iowan Old Style", "Georgia", serif;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .chapter-summary {
    margin: 1.1rem 0 0;
    color: rgba(39, 39, 42, 0.74);
    font-size: 1.02rem;
    line-height: 1.55;
    max-width: 64ch;
    font-family: "Merriweather", "Quicksand", "Avenir Next", "Segoe UI", sans-serif;
    font-weight: 500;
    letter-spacing: 0.004em;
    background: rgba(21, 106, 130, 0.05);
    border: 1px solid rgba(21, 106, 130, 0.2);
    border-radius: 10px;
    padding: 0.55rem 0.72rem 0.58rem;
    display: inline-block;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.46);
    position: relative;
  }

  .chapter-body {
    margin-top: 1.25rem;
    color: var(--text-secondary);
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .chapter-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .chapter-shell {
      scroll-margin-top: 4.8rem;
    }

    .chapter-main {
      padding: 0.88rem;
      border-radius: 14px;
    }

    h2 {
      font-size: 1.45rem;
      line-height: 1.12;
    }

    .chapter-summary {
      display: block;
      margin-top: 0.75rem;
      padding: 0.5rem 0.58rem;
      font-size: 0.93rem;
      line-height: 1.48;
    }

    .chapter-body {
      margin-top: 0.85rem;
      gap: 0.78rem;
    }
  }
</style>
