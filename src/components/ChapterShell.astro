---
interface Props {
  id: string;
  aliasIds?: string[];
  number: string;
  title: string;
  summary: string;
}

const { id, aliasIds = [], number, title, summary } = Astro.props;
---

{aliasIds.map((aliasId) => <span id={aliasId} class="chapter-anchor-alias" aria-hidden="true" />)}
<section id={id} class="chapter-shell" aria-labelledby={`chapter-${number}`}>
  <div class="chapter-content">
    <article class="chapter-main">
      <p class="chapter-kicker">Chapter {number}</p>
      <h2 id={`chapter-${number}`}>{title}</h2>
      <p class="chapter-summary">{summary}</p>
      <div class="chapter-body">
        <slot />
      </div>
    </article>
  </div>
</section>

<style>
  .chapter-shell {
    scroll-margin-top: 6rem;
    --chapter-accent: var(--brand-cyan);
    --chapter-accent-rgb: 21, 106, 130;
    --chapter-accent-soft: rgba(var(--chapter-accent-rgb), 0.1);
    --chapter-accent-line: rgba(var(--chapter-accent-rgb), 0.34);
  }

  .chapter-anchor-alias {
    display: block;
    height: 0;
    scroll-margin-top: 6rem;
  }

  .chapter-shell:nth-of-type(3n + 1) {
    --chapter-accent: #156a82;
    --chapter-accent-rgb: 21, 106, 130;
  }

  .chapter-shell:nth-of-type(3n + 2) {
    --chapter-accent: #5b4f9d;
    --chapter-accent-rgb: 91, 79, 157;
  }

  .chapter-shell:nth-of-type(3n) {
    --chapter-accent: #1f7a63;
    --chapter-accent-rgb: 31, 122, 99;
  }

  #c1,
  #c2 {
    --chapter-accent: #0e7490;
    --chapter-accent-rgb: 14, 116, 144;
  }

  #c3,
  #c4 {
    --chapter-accent: #b45309;
    --chapter-accent-rgb: 180, 83, 9;
  }

  #c5,
  #c14 {
    --chapter-accent: #0284c7;
    --chapter-accent-rgb: 2, 132, 199;
  }

  #c6,
  #c7,
  #c12,
  #c13 {
    --chapter-accent: #be185d;
    --chapter-accent-rgb: 190, 24, 93;
  }

  #c8,
  #c9,
  #c10,
  #c11 {
    --chapter-accent: #156a82;
    --chapter-accent-rgb: 21, 106, 130;
  }

  #c15 {
    --chapter-accent: #c0266f;
    --chapter-accent-rgb: 192, 38, 111;
  }

  .chapter-content {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .chapter-main {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(var(--chapter-accent-rgb), 0.22);
    background:
      radial-gradient(circle at 100% 0%, rgba(var(--chapter-accent-rgb), 0.085), transparent 35%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.94), rgba(250, 247, 239, 0.9) 54%, rgba(246, 239, 224, 0.82));
    box-shadow: 0 14px 34px rgba(39, 39, 42, 0.08);
    padding: 1.45rem;
    position: relative;
  }

  .chapter-main::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    background: linear-gradient(180deg, rgba(var(--chapter-accent-rgb), 0.72), rgba(var(--chapter-accent-rgb), 0.08));
    pointer-events: none;
  }

  .chapter-kicker {
    margin: 0;
    color: var(--chapter-accent);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  h2 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.4rem, 2.8vw, 2.1rem);
    font-family: "Fraunces", "Iowan Old Style", "Georgia", serif;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #111827;
  }

  .chapter-summary {
    margin: 0.82rem 0 0;
    color: rgba(39, 39, 42, 0.8);
    font-size: 1.03rem;
    line-height: 1.55;
    max-width: 64ch;
    font-family: "Merriweather", "Quicksand", "Avenir Next", "Segoe UI", sans-serif;
    font-weight: 500;
    letter-spacing: 0.004em;
    border-left: 3px solid rgba(var(--chapter-accent-rgb), 0.48);
    padding: 0.12rem 0 0.14rem 0.78rem;
    display: block;
    position: relative;
  }

  .chapter-body {
    margin-top: 1.25rem;
    color: var(--text-secondary);
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .chapter-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .chapter-shell {
      scroll-margin-top: 4.8rem;
    }

    .chapter-main {
      padding: 0.88rem;
      border-radius: 14px;
    }

    h2 {
      font-size: 1.45rem;
      line-height: 1.12;
    }

    .chapter-summary {
      display: block;
      margin-top: 0.75rem;
      padding: 0.5rem 0.58rem;
      font-size: 0.93rem;
      line-height: 1.48;
    }

    .chapter-body {
      margin-top: 0.85rem;
      gap: 0.78rem;
    }
  }
</style>
